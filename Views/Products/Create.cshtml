@model StockControl.Models.Product
@{
    ViewData["Title"] = "Urun Ekle";
}

<div class="card">
    <h2>Yeni Urun</h2>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="grid">
            <div>
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="UnitPrice"></label>
                <input asp-for="UnitPrice" type="number" step="0.01" />
                <span asp-validation-for="UnitPrice" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Category"></label>
                <select asp-for="Category">
                    @foreach (var category in (string[])(ViewBag.Categories ?? Array.Empty<string>()))
                    {
                        <option value="@category">@category</option>
                    }
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Quantity"></label>
                <input asp-for="Quantity" type="number" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div>
                <label>Urun Fotografi</label>
                <input type="file" name="imageFile" accept=".png,.jpg,.jpeg,.webp" />
            </div>
        </div>
        <br />
        <p><b>Urun Kodu:</b> Kayit sirasinda otomatik olusturulur.</p>
        <br />
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a asp-action="Index" class="btn btn-secondary">Iptal</a>
    </form>
</div>
