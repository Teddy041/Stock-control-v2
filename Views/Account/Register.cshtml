@model StockControl.ViewModels.RegisterVm
@{
    ViewData["Title"] = "Kayit Ol";
}

<div class="card" style="max-width: 480px; margin: 0 auto;">
    <h2>Kayit Ol</h2>
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div>
            <label asp-for="UserName"></label>
            <input asp-for="UserName" autocomplete="username" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>
        <br />
        <div>
            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <br />
        <div>
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <br />
        <div class="actions">
            <button class="btn btn-primary" type="submit">Kayit Ol</button>
            <a class="btn btn-secondary" asp-action="Login">Giris'e Don</a>
        </div>
    </form>
</div>
